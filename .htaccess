PassengerEnabled on
PassengerAppRoot /home/gaak4328/logersenegal.com
PassengerAppType wsgi
PassengerStartupFile passenger_wsgi.py
PassengerPython /home/gaak4328/virtualenv/logersenegal.com/3.11/bin/python

RewriteEngine On
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^(.*)$ /passenger_wsgi.py/$1 [QSA,L]
